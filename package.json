{
  "name": "daily-activity",
  "version": "1.3.1",
  "description": "Production-grade Node.js service with Redis caching, job queues and circuit breakers",
  "main": "src/index.js",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "audit": "npm audit --audit-level=moderate",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.0",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": { "global": { "branches": 80, "functions": 80, "lines": 80 } }
  }
}
